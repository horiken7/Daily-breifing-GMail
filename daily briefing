function buildEventsHtml(events) {
  if (events.length === 0) {
    return '<div class="no-data">今日の予定はありません</div>';
  }

  return events.map(ev => {
    const timeLabel = ev.allDay ? "終日" : `${ev.start}〜${ev.end}`;
    const locHtml   = ev.location
      ? `<div class="event-location">${ev.location}</div>`
      : "";
    const dotColor  = ev.color || "#aaaaaa";
    return `
    <div class="event-item">
      <div class="event-dot" style="color:${dotColor};">&#9679;</div>
      <div class="event-time">${timeLabel}</div>
      <div>
        <div class="event-title">${ev.title}</div>
        ${locHtml}
      </div>
    </div>`;
  }).join("");
}

function buildTasksHtml(tasks) {
  if (tasks.length === 0) {
    return '<div class="no-data">対象タスクはありません</div>';
  }

  // 3分類に振り分け
  const overdueTasks = tasks.filter(t => t.isOverdue);
  const todayTasks   = tasks.filter(t => t.isToday);
  const futureTasks  = tasks.filter(t => !t.isOverdue && !t.isToday);

  function renderTask(t) {
    const dotColor  = t.color || "#9e9e9e";
    const dateLabel = t.isOverdue
      ? `<span class="task-overdue">[期限切れ] ${t.dueDate}</span>`
      : `<span class="task-date">期日: ${t.dueDate}</span>`;
    const metaHtml  = `<div class="task-meta"><span class="task-list-name">${t.listName}</span> ・ ${dateLabel}</div>`;
    const notesHtml = t.notes ? `<div class="task-notes">${t.notes}</div>` : "";
    return `
    <div class="task-item">
      <div class="task-dot" style="color:${dotColor};">&#9679;</div>
      <div class="task-checkbox">&#9744;</div>
      <div>
        <div class="task-title">${t.title}</div>
        ${metaHtml}
        ${notesHtml}
      </div>
    </div>`;
  }

  var html = "";

  if (overdueTasks.length > 0) {
    html += '<div class="task-section-label task-label-overdue">[期限切れ] 未完了タスク</div>';
    html += overdueTasks.map(renderTask).join("");
  }
  if (todayTasks.length > 0) {
    html += '<div class="task-section-label task-label-today">[今日] 本日が期日のタスク</div>';
    html += todayTasks.map(renderTask).join("");
  }
  if (futureTasks.length > 0) {
    html += '<div class="task-section-label task-label-future">[今後] 今後1週間のタスク</div>';
    html += futureTasks.map(renderTask).join("");
  }

  return html;
}

function buildEmailsHtml(emails) {
  if (emails.length === 0) {
    return '<div class="no-data">重要なメールはありません</div>';
  }

  return emails.map(m => {
    const unreadBadge    = m.isUnread    ? '<span class="badge badge-unread">未読</span>'    : "";
    const importantBadge = m.isImportant ? '<span class="badge badge-important">重要</span>' : "";
    return `
    <div class="mail-item">
      <div class="mail-subject">
        <a href="${m.link}">${m.subject}</a>${unreadBadge}${importantBadge}
      </div>
      <div class="mail-meta">差出人: ${m.from} ・ ${m.date}</div>
      <div class="mail-snippet">${m.snippet}</div>
    </div>`;
  }).join("");
}
