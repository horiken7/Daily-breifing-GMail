// ==============================
// メイン処理
// ==============================
function sendDailyBriefing() {
  const today   = new Date();
  const dateStr = Utilities.formatDate(today, "Asia/Tokyo", "yyyy年M月d日(EEE)")
    .replace("Mon","月").replace("Tue","火").replace("Wed","水")
    .replace("Thu","木").replace("Fri","金").replace("Sat","土").replace("Sun","日");

  const calendarSection = getCalendarSection(today);
  const tasksSection    = getTasksSection();
  const emailSection    = getEmailSection(today);

  const htmlBody = buildHtmlEmail(dateStr, calendarSection, tasksSection, emailSection);

  GmailApp.sendEmail(
    CONFIG.SEND_TO,
    CONFIG.SUBJECT_PREFIX + dateStr,
    "HTMLメールが表示されない場合はGmailでご確認ください。",
    { htmlBody: htmlBody }
  );

  Logger.log("デイリーブリーフィング送信完了: " + dateStr);
}

// ==============================
// ToDoリスト（Tasks）の取得
// ==============================
function getTasksSection() {
  const results = [];

  try {
    // タスクリスト一覧を取得（GAS Tasks APIの正しい呼び出し形式）
    const taskListResponse = Tasks.Tasklists.list();
    const taskLists = taskListResponse.items;
    if (!taskLists || taskLists.length === 0) {
      Logger.log("Tasks: タスクリストが0件");
      return results;
    }

    Logger.log("Tasks: タスクリスト数 = " + taskLists.length);

    const now = new Date();

    const todayStart = new Date(now);
    todayStart.setHours(0, 0, 0, 0);

    const oneWeekLater = new Date(todayStart);
    oneWeekLater.setDate(oneWeekLater.getDate() + 7);
    oneWeekLater.setHours(23, 59, 59, 999);

    taskLists.forEach(function(list) {
      try {
        // GAS Tasks APIの正しいオプション渡し方
        const taskResponse = Tasks.Tasks.list(list.id, {
          showCompleted: false,
          showHidden:    false,
          maxResults:    100
        });
        const tasks = taskResponse.items;
        Logger.log("Tasks: リスト[" + list.title + "] タスク数 = " + (tasks ? tasks.length : 0));
        if (!tasks || tasks.length === 0) return;

        tasks.forEach(function(task) {
          if (task.status === "completed") return;
          if (!task.title || task.title.trim() === "") return;
          if (!task.due) return;

          // dueはUTC 0時で返る（例: "2026-03-16T00:00:00.000Z"）
          // そのままnew Date()すると日本時間09:00になるため、
          // 日付文字列（YYYY-MM-DD）だけ取り出して日本時間0時として比較する
          var dueDateStr = task.due.substring(0, 10); // "2026-03-16"
          var dueParts   = dueDateStr.split("-");
          var due        = new Date(
            parseInt(dueParts[0]),
            parseInt(dueParts[1]) - 1,
            parseInt(dueParts[2]),
            0, 0, 0, 0
          );

          var isOverdue    = due < todayStart;
          var isWithinWeek = due <= oneWeekLater;

          Logger.log("Tasks: タスク[" + task.title + "] due=" + dueDateStr + " overdue=" + isOverdue + " withinWeek=" + isWithinWeek);

          if (!isOverdue && !isWithinWeek) return;

          var isToday = !isOverdue && (due.getTime() === todayStart.getTime());
          var taskColor = CONFIG.TASK_COLORS[list.title] || CONFIG.TASK_COLOR_DEFAULT;

          results.push({
            title:     task.title,
            listName:  list.title,
            dueDate:   Utilities.formatDate(due, "Asia/Tokyo", "M/d"),
            isOverdue: isOverdue,
            isToday:   isToday,
            color:     taskColor,
            notes:     task.notes ? task.notes.substring(0, 60) : ""
          });
        });
      } catch(listErr) {
        Logger.log("Tasks: リスト[" + list.title + "]の取得エラー: " + listErr.message);
      }
    });

    Logger.log("Tasks: 最終結果件数 = " + results.length);

  } catch(e) {
    Logger.log("Tasks取得エラー: " + e.message);
  }

  return results;
}

// ==============================
// カレンダー情報の取得
// ==============================
function getCalendarSection(today) {
  const startOfDay = new Date(today);
  startOfDay.setHours(0, 0, 0, 0);

  const endOfDay = new Date(today);
  endOfDay.setHours(23, 59, 59, 999);

  let events = [];

  CONFIG.CALENDAR_IDS.forEach(calId => {
    try {
      const cal = CalendarApp.getCalendarById(
        calId === "primary" ? Session.getActiveUser().getEmail() : calId
      );
      if (!cal) return;

      var calColor = CONFIG.CALENDAR_COLORS[calId] || "#aaaaaa";
      cal.getEvents(startOfDay, endOfDay).forEach(e => {
        events.push({
          title:    e.getTitle(),
          start:    e.isAllDayEvent() ? "終日" : Utilities.formatDate(e.getStartTime(), "Asia/Tokyo", "HH:mm"),
          end:      e.isAllDayEvent() ? ""     : Utilities.formatDate(e.getEndTime(),   "Asia/Tokyo", "HH:mm"),
          location: e.getLocation() || "",
          allDay:   e.isAllDayEvent(),
          color:    calColor
        });
      });
    } catch(e) {
      Logger.log("カレンダー取得エラー (" + calId + "): " + e.message);
    }
  });

  const seen = new Set();
  events = events.filter(ev => {
    const key = ev.title + ev.start;
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });

  events.sort((a, b) => {
    if (a.allDay && !b.allDay) return -1;
    if (!a.allDay && b.allDay) return 1;
    return a.start.localeCompare(b.start);
  });

  return events;
}

// ==============================
// メール情報の取得
// ==============================
function getEmailSection(today) {
  const since = new Date(today);
  since.setDate(since.getDate() - CONFIG.DAYS_BACK_FOR_MAIL);
  since.setHours(0, 0, 0, 0);

  const afterStr = Utilities.formatDate(since, "Asia/Tokyo", "yyyy/MM/dd");
  const excludes = CONFIG.EXCLUDED_CATEGORIES.join(" -");
  const query    = `after:${afterStr} -${excludes} -from:me`;

  const threads = GmailApp.search(query, 0, 30);
  const results = [];

  threads.forEach(thread => {
    const messages   = thread.getMessages();
    const last       = messages[messages.length - 1];
    const isUnread   = thread.isUnread();
    const isImportant = thread.isImportant();

    if (!isUnread && !isImportant) return;

    results.push({
      subject:     thread.getFirstMessageSubject(),
      from:        last.getFrom(),
      date:        Utilities.formatDate(last.getDate(), "Asia/Tokyo", "M/d HH:mm"),
      isUnread:    isUnread,
      isImportant: isImportant,
      snippet:     last.getPlainBody().substring(0, 120).replace(/\s+/g, " ").trim() + "...",
      link:        "https://mail.google.com/mail/u/0/#inbox/" + thread.getId()
    });
  });

  return results;
}

